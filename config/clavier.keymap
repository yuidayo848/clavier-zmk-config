/*
 * Clavier キーマップ
 *
 * ── 左手側 物理配置 (20キー) ─────────────────────────────────────────
 *
 *  上段 (6キー):   CTRL   Q    W    E    R    T
 *  中段 (6キー):   GUI    A    S    D    F    G
 *  下段 (6キー):   ALT    Z    X    C    V    B
 *  親指 (2キー):                            LWR  SPC
 *
 *  ※ 最外列 (小指) は CTRL/GUI/ALT の3キー
 *
 * ── 右手側 物理配置 (24キー) ─────────────────────────────────────────
 *
 *  Row0:  Y    U    I    O    P    [
 *  Row1:  H    J    K    L    ;    '
 *  Row2:  N    M    ,    .    /    ]
 *  Row3:  SPC  RSE  ENT  BSPC DEL  \
 *
 * ── キーマップ記述順 ─────────────────────────────────────────────────
 *  位置 0-19  : 左側 (物理配置順: 上段6 → 中段6 → 下段6 → 親指2)
 *  位置 20-43 : 右側 (行順: Row0×6 → Row1×6 → Row2×6 → Row3×6)
 *
 * ── レイヤー ──────────────────────────────────────────────────────
 *  0: QWERTY (デフォルト)
 *  1: LOWER  (数字・記号)
 *  2: RAISE  (ファンクション・ナビゲーション・BT)
 *  3: MOUSE  (トラックボール自動有効化)
 *
 * ── BLE ペアリング PIN 入力方法 ──────────────────────────────────────
 *  LOWER(親指1)を押しながら数字を入力:
 *    1=Q, 2=W, 3=E, 4=R, 5=T  (左手 LOWER 上段)
 *    6=Y, 7=U, 8=I, 9=O, 0=P  (右手 LOWER 上段)
 *  入力後、ENT (右手 Row3 の3番目) で確定
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>

#define DEFAULT 0
#define LOWER   1
#define RAISE   2
#define MOUSE   3

/ {
    keymap {
        compatible = "zmk,keymap";

        /* ─── Layer 0: QWERTY (デフォルト) ────────────────────────── */
        default_layer {
            bindings = <
            /* 左側上段 (6キー): 外列=CTRL, Q W E R T */
            &kp LCTRL  &kp Q  &kp W  &kp E  &kp R  &kp T
            /* 左側中段 (6キー): 外列=GUI,  A S D F G */
            &kp LGUI   &kp A  &kp S  &kp D  &kp F  &kp G
            /* 左側下段 (6キー): 外列=ALT,  Z X C V B */
            &kp LALT   &kp Z  &kp X  &kp C  &kp V  &kp B
            /* 左側親指 (2キー): LWR, SPC */
            &mo LOWER  &kp SPACE
            /* 右側 Row0 (6キー): Y U I O P [ */
            &kp Y  &kp U  &kp I  &kp O  &kp P  &kp LBKT
            /* 右側 Row1 (6キー): H J K L ; ' */
            &kp H  &kp J  &kp K  &kp L  &kp SEMI  &kp SQT
            /* 右側 Row2 (6キー): N M , . / ] */
            &kp N  &kp M  &kp COMMA  &kp DOT  &kp FSLH  &kp RBKT
            /* 右側 Row3 (6キー): SPC RSE ENT BSPC DEL \ */
            &kp SPACE  &mo RAISE  &kp RET  &kp BSPC  &kp DEL  &kp BSLH
            >;
        };

        /* ─── Layer 1: LOWER (数字・記号) ──────────────────────────── */
        lower_layer {
            bindings = <
            /* 左側上段: ESC, 1 2 3 4 5 */
            &kp ESC   &kp N1  &kp N2  &kp N3  &kp N4  &kp N5
            /* 左側中段: TAB, ! @ # $ % */
            &kp TAB   &kp EXCL  &kp AT  &kp HASH  &kp DLLR  &kp PRCNT
            /* 左側下段: CAPS, ` ~ none none none */
            &kp CAPS  &kp GRAVE  &kp TILDE  &none  &none  &none
            /* 左側親指: trans, trans */
            &trans  &trans
            /* 右側 Row0: 6 7 8 9 0 - */
            &kp N6  &kp N7  &kp N8  &kp N9  &kp N0  &kp MINUS
            /* 右側 Row1: ^ & * ( ) = */
            &kp CARET  &kp AMPS  &kp ASTRK  &kp LPAR  &kp RPAR  &kp EQUAL
            /* 右側 Row2: none ... + */
            &none  &none  &none  &none  &none  &kp PLUS
            /* 右側 Row3: trans×6 */
            &trans  &trans  &trans  &trans  &trans  &trans
            >;
        };

        /* ─── Layer 2: RAISE (Fキー・ナビゲーション・BT) ───────────── */
        raise_layer {
            bindings = <
            /* 左側上段: ESC, F1 F2 F3 F4 F5 */
            &kp ESC  &kp F1  &kp F2  &kp F3  &kp F4  &kp F5
            /* 左側中段: TAB, F11 F12 INS none none */
            &kp TAB  &kp F11  &kp F12  &kp INS  &none  &none
            /* 左側下段: CAPS, BT0 BT1 BT2 BTCLR none */
            &kp CAPS  &bt BT_SEL 0  &bt BT_SEL 1  &bt BT_SEL 2  &bt BT_CLR  &none
            /* 左側親指: trans, trans */
            &trans  &trans
            /* 右側 Row0: F6 F7 F8 F9 F10 none */
            &kp F6  &kp F7  &kp F8  &kp F9  &kp F10  &none
            /* 右側 Row1: ← ↓ ↑ → END HOME */
            &kp LEFT  &kp DOWN  &kp UP  &kp RIGHT  &kp END  &kp HOME
            /* 右側 Row2: PGDN PGUP none none PSCRN none */
            &kp PG_DN  &kp PG_UP  &none  &none  &kp PSCRN  &none
            /* 右側 Row3: trans×6 */
            &trans  &trans  &trans  &trans  &trans  &trans
            >;
        };

        /* ─── Layer 3: MOUSE (トラックボール自動有効化) ─────────────── */
        mouse_layer {
            bindings = <
            &trans &trans &trans &trans &trans &trans
            &trans &trans &trans &trans &trans &trans
            &trans &trans &trans &trans &trans &trans
            &trans &trans
            &trans &trans &trans &trans &trans &trans
            &trans &trans &trans &trans &trans &trans
            &trans &trans &trans &trans &trans &trans
            &trans &trans &trans &trans &trans &trans
            >;
        };
    };
};
