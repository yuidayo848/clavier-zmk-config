#include <dt-bindings/zmk/matrix_transform.h>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,matrix-transform = &default_transform;
    };

    /* * 【決定版】回路図マトリクス基準・トランスフォーム定義
     * * 物理的なキーのレイアウトは一切無視し、回路図（電子回路）の格子通りに
     * 部屋番号（インデックス 0 〜 43）をストレートに割り当てます。
     * これにより、マイコンの認識ズレ（キーの化け）を根本から防ぎます。
     * * ──────────────────────────────────────────────────────────
     * RC( 1つ目の数字 , 2つ目の数字 ) の読み方解説：
     * * RC( 行番号 , 列番号 ) ──＞ RC( Row , Column ) の略です。
     * * ・1つ目の数字【行 (Row)】   ：電気回路の「横の列（ライン）」を指します。
     * 左右共通で 0 〜 3 の合計4行あります。
     * ・2つ目の数字【列 (Column)】：電気回路の「縦の列（ライン）」を指します。
     * 左手(0〜4) ＋ 右手(5〜10) の合計11列あります。
     * ──────────────────────────────────────────────────────────
     */
    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <11>; // 全体の総列数（左5 + 右6）
        rows = <4>;    // 全体の総行数

        map = <
            /* ＝＝＝＝＝＝＝＝＝＝ 左手側 (位置 0 〜 19) ＝＝＝＝＝＝＝＝＝＝
             * 回路図の「4行 × 5列」の格子に、そのまま 0 から順番に背番号を振ります。
             * [Col0]   [Col1]   [Col2]   [Col3]   [Col4]
             */
            RC(0,0)  RC(0,1)  RC(0,2)  RC(0,3)  RC(0,4)  // Row0 (位置 0〜4)
            RC(1,0)  RC(1,1)  RC(1,2)  RC(1,3)  RC(1,4)  // Row1 (位置 5〜9)
            RC(2,0)  RC(2,1)  RC(2,2)  RC(2,3)  RC(2,4)  // Row2 (位置 10〜14)
            RC(3,0)  RC(3,1)  RC(3,2)  RC(3,3)  RC(3,4)  // Row3 (位置 15〜19)

            /* ＝＝＝＝＝＝＝＝＝＝ 右手側 (位置 20 〜 43) ＝＝＝＝＝＝＝＝＝＝
             * 回路図の「4行 × 6列」の格子です。
             * ZMK Splitの自動オフセット仕様により、右手側のローカル列番号（Col0〜5）には、
             * 左手側の列数「5」が自動的に加算され、[Col5 〜 Col10] として結合されます。
             * [Col5]   [Col6]   [Col7]   [Col8]   [Col9]   [Col10]
             */
            RC(0,5)  RC(0,6)  RC(0,7)  RC(0,8)  RC(0,9)  RC(0,10) // Row0 (位置 20〜25)
            RC(1,5)  RC(1,6)  RC(1,7)  RC(1,8)  RC(1,9)  RC(1,10) // Row1 (位置 26〜31)
            RC(2,5)  RC(2,6)  RC(2,7)  RC(2,8)  RC(2,9)  RC(2,10) // Row2 (位置 32〜37)
            RC(3,5)  RC(3,6)  RC(3,7)  RC(3,8)  RC(3,9)  RC(3,10) // Row3 (位置 38〜43)
        >;
    };
};
