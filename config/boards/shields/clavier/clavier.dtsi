/*
 * Clavier - 分割キーボード共通定義
 *
 * 左手側 (20キー: 4行×5列) ピンアサイン:
 *   Row0: P0.03  Row1: P0.28  Row2: P0.29  Row3: P1.11
 *   Col0: P0.10  Col1: P1.12  Col2: P1.13  Col3: P1.14  Col4: P1.15
 *
 * 右手側 (24キー: 4行×6列) ピンアサイン:
 *   Row0: P0.03  Row1: P0.29  Row2: P0.05  Row3: P1.11
 *   Col0: P1.15  Col1: P1.14  Col2: P1.12  Col3: P1.13  Col4: P0.04  Col5: P0.02
 *
 * ダイオード方向: Col→Switch→Diode(A→K)→Row (col2row)
 */

#include <dt-bindings/zmk/matrix_transform.h>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,matrix-transform = &default_transform;
    };

    /*
     * 全体マトリクス: 4行 × 11列
     * 左側5キー × 4行 + 右側6キー × 4行 = 合計44キー
     *
     * ZMK split では Central(左) のキーが位置 0-19、
     * Peripheral(右) のキーが位置 20-43 に割り当てられるため、
     * 左側全行 → 右側全行 の順で並べる必要がある。
     */
    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <11>;
        rows = <4>;
        map = <
            /* 左側 (positions 0-19): 4行 × 5列 */
            RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4)
            RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4)
            RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4)
            RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4)
            /* 右側 (positions 20-43): 4行 × 6列 */
            RC(0,5) RC(0,6) RC(0,7) RC(0,8) RC(0,9) RC(0,10)
            RC(1,5) RC(1,6) RC(1,7) RC(1,8) RC(1,9) RC(1,10)
            RC(2,5) RC(2,6) RC(2,7) RC(2,8) RC(2,9) RC(2,10)
            RC(3,5) RC(3,6) RC(3,7) RC(3,8) RC(3,9) RC(3,10)
        >;
    };
};
