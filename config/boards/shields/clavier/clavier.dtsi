/*
 * Clavier - 分割キーボード共通定義
 *
 * ── 左手側 物理配置 (20キー) ──────────────────────────────────────────
 *
 *  物理列(PX):  95.6   112.6   129.6   146.6   163.6   180.6
 *              小指    薬指    中指-高  中指    人差し  人差し内
 *
 *  上段:  SW2    SW6    SW10   SW11   SW14   SW18
 *         C0R0   C1R0   C2R0   C2R1   C3R0   C4R0
 *  中段:  SW3    SW7    SW8    SW12   SW15   SW19
 *         C0R1   C1R1   C1R2   C2R2   C3R1   C4R1
 *  下段:  SW4    SW5    SW9    SW13   SW16   SW20
 *         C0R2   C0R3   C1R3   C2R3   C3R2   C4R2
 *  親指:  SW17(C3R3)  SW21(C4R3)
 *
 *  ※ 最外列(小指列)は上・中・下の3キーのみ
 *  ※ 回路図の行列番号と物理列が異なる（PCB配線最適化のため）
 *
 * ── 右手側 電気マトリクス (4行×6列 = 24キー) ──────────────────────────
 *   Row0: P0.03  Row1: P0.29  Row2: P0.05  Row3: P1.11
 *   Col0: P1.15  Col1: P1.14  Col2: P1.12  Col3: P1.13  Col4: P0.04  Col5: P0.02
 *
 * ── ZMK split キー位置番号 ────────────────────────────────────────────
 *   左側 (Central)  : 位置 0〜19
 *   右側 (Peripheral): 位置 20〜43 (右ローカル + オフセット20)
 */

#include <dt-bindings/zmk/matrix_transform.h>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,matrix-transform = &default_transform;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <11>;
        rows = <4>;
        map = <
            /* ── 左側 (positions 0-19): 物理配置順 ── */

            /* 上段 6キー: 小指外, Q(C1R0), W(C2R0), E(C2R1), R(C3R0), T(C4R0) */
            RC(0,0)  RC(0,1)  RC(0,2)  RC(1,2)  RC(0,3)  RC(0,4)

            /* 中段 6キー: 小指外, A(C1R1), S(C1R2), D(C2R2), F(C3R1), G(C4R1) */
            RC(1,0)  RC(1,1)  RC(2,1)  RC(2,2)  RC(1,3)  RC(1,4)

            /* 下段フィンガー 6キー: 小指外, Z(C0R3), X(C1R3), C(C2R3), V(C3R2), B(C4R2) */
            RC(2,0)  RC(3,0)  RC(3,1)  RC(3,2)  RC(2,3)  RC(2,4)

            /* 親指 2キー: LWR(C3R3), SPC(C4R3) */
            RC(3,3)  RC(3,4)

            /* ── 右側 (positions 20-43): 4行×6列、行順 ── */
            RC(0,5)  RC(0,6)  RC(0,7)  RC(0,8)  RC(0,9)  RC(0,10)
            RC(1,5)  RC(1,6)  RC(1,7)  RC(1,8)  RC(1,9)  RC(1,10)
            RC(2,5)  RC(2,6)  RC(2,7)  RC(2,8)  RC(2,9)  RC(2,10)
            RC(3,5)  RC(3,6)  RC(3,7)  RC(3,8)  RC(3,9)  RC(3,10)
        >;
    };
};
